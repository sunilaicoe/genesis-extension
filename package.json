{
  "name": "hello-world",
  "displayName": "Hello World Extension",
  "description": "A VS Code extension with sidebar navigation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:helloWorldSidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helloWorldSidebar",
          "title": "Hello World",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "helloWorldSidebar": [
        {
          "type": "webview",
          "id": "helloWorldSidebarView",
          "name": "Hello World"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}
